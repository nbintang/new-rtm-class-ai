DATABASE_URL=postgresql://rtm_class_user:rtm_class_password@localhost:5433/rtm_class?schema=public
DATABASE_URL_DOCKER=postgresql://rtm_class_user:rtm_class_password@host.docker.internal:5433/rtm_class?schema=public
GROQ_API_KEY=PASTE_YOUR_GROQ_API_KEY_HERE
PORT=5001
MCP_SERVER_URL=http://localhost:5002/mcp
MCP_SERVER_URL_DOCKER=http://host.docker.internal:5002/mcp
CORS_ORIGIN=*
OAUTH_CLIENT_ID=rtm-client
OAUTH_CLIENT_SECRET=change-me
OAUTH_ALLOWED_SCOPES=material:write lkpd:write lkpd:read
OAUTH_ACCESS_TOKEN_TTL=300
JWT_SECRET=change-this-jwt-secret
JWT_ISSUER=my-backend
JWT_AUDIENCE=rtm-class-ai
